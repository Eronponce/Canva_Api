FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false

# Banco principal do painel.
# Producao recomendada: MySQL
# Exemplo:
# DATABASE_URL=mysql+pymysql://usuario:senha@localhost:3306/canvas_bulk_panel
DATABASE_URL=
# DATABASE_ECHO=false

# Opcional: pode deixar em branco e informar pela interface.
CANVAS_BASE_URL= 

# Use qualquer uma das opções abaixo.
# O painel aceita tanto token pessoal quanto API token / access token.
CANVAS_ACCESS_TOKEN=
CANVAS_PERSONAL_ACCESS_TOKEN= 
# CANVAS_API_TOKEN=

CANVAS_REQUEST_TIMEOUT=30
CANVAS_RETRY_MAX_ATTEMPTS=4
CANVAS_RETRY_BASE_DELAY=1.5
HISTORY_LIMIT=25
ENABLE_LEGACY_JSON_IMPORT=false

# Opcional: sobrescreva se quiser guardar histórico/logs em outra pasta.
# CANVAS_PANEL_DATA_DIR=
# CANVAS_PANEL_LOGS_DIR=
